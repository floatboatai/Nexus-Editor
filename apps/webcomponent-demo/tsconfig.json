{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM"],
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@floatboat/nexus-webcomponent": ["../../packages/webcomponent/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts"]
}
